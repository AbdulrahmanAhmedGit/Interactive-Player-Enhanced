# Firebase Configuration
# These are the standard Firebase config keys if you need to connect to a backend
VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

# Note: In the project's InteractiveVideo.jsx, Firebase is initialized using a global 
# variable __firebase_config (often injected via script tag or window object).
# Ensure Vercel or your bundler exposes the config appropriately if using these environment variables.
